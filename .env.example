# QA API Pilot - example .env
# Copy this to .env and fill in values for your project.
# /qa-api-test-setup will create .env automatically the first time it runs - use this file
# only if you want to pre-fill values or troubleshoot a fresh setup.

# ----- API target -----

# Server root. URL preferred; the agent will use this for the Newman base URL.
BASE_URL=https://api.example.com

# OpenAPI spec source. Either a URL or an absolute/relative file path.
OPENAPI_SPEC=https://api.example.com/docs/openapi.json
# OPENAPI_SPEC=./openapi.json

# Health-check path - used by run-tests.sh to ping the server before running the suite.
# Usually a public-ish endpoint that returns 200 or 401.
HEALTH_PATH=/api/v1/health

# ----- Auth credentials -----

# Test account login (used by the Login request in the collection at runtime).
LOGIN_EMAIL=test@example.com
LOGIN_PASSWORD=changeme

# Platform/API key (used if any endpoints in the spec are secured by an apiKey scheme).
# Leave empty if your API is JWT-only.
PLATFORM_API_KEY=

# ----- Jira (auto-populated on first /qa-test-ticket call) -----

# Jira project key extracted from the first ticket you build (e.g. PROJ-123 -> PROJ).
# Used by the Phase 9 bug-logging gate to know where to file tickets.
JIRA_PROJECT_KEY=

# ----- Optional auth overrides -----
#
# The agent auto-detects these three from your OpenAPI spec during /qa-api-test-setup:
#   - AUTH_TYPE          from components.securitySchemes
#   - LOGIN_PATH         from tagged auth operations / path heuristics
#   - TOKEN_JSON_PATH    by walking the login endpoint's response schema, verified
#                        by one live login call
#
# Uncomment + edit only if the agent's auto-detection is wrong for your API
# (e.g. spec is incomplete, or response shape differs from documented).
#
# AUTH_TYPE=jwt                                            # jwt | apikey | both
# LOGIN_PATH=/api/v1/auth/login
# TOKEN_JSON_PATH=payload.data.tokens.accessToken

# ----- Notes -----
#
# NEVER put POSTMAN_API_KEY in this file. It lives in the GLOBAL Claude Code config at
# ~/.claude/settings.json (the .claude/ directory in your HOME folder, NOT the project-local
# .claude/ folder in this repo) under env.POSTMAN_API_KEY. It is a plugin credential shared
# across every project on your machine.
#
# NEVER put workspace IDs in this file. /qa-api-test-setup lists workspaces live and asks
# you to pick one - the choice is not persisted.
#
# One-off entity IDs (e.g. a specific PO ID, a single branch ID for one ticket) do NOT belong
# here. Only persistent credentials and API keys.
