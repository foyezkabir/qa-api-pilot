  "env": {
    "POSTMAN_API_KEY": "PMAK-xxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
  },
  "permissions": {
    "allow": [
      "mcp__plugin_postman_postman__*",
      "Bash(curl *)",
