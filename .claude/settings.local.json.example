      "Bash(./run-tests.sh)",
      "Bash(python3 -c ' *)",
      "Bash(python3 -m json.tool)",
      "Bash(python3 *)",
      "Bash(node *)",
      "Bash(newman run *)",
      "Read(//tmp/**)"
    ]
  }
}
